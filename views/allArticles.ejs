<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>All Articles</h1>
    <hr />
    <div class="articles" style="padding: 20px; background-color: black; border-radius: 10px;">

        <% for( let article of allArticles ) { %>
            <div class="article" style="background-color: white; border-radius: 10px; padding: 10px;">

                <h1 ><%=article.title%></h1>
                <h5><%=article.body%></h5>

            </div>
            <hr>
            <% } %>
        </div>
  </body>
</html>
